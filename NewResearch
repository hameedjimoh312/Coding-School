        "def random_time_picker(text_value):\n",
        "    if text_value == 'Less than 15 minutes a day':\n",
        "        return np.random.randint(5, 15)\n",
        "    elif text_value == '15-30 minutes a day':\n",
        "        return np.random.randint(15, 31)\n",
        "    elif text_value == '30-60 minutes a day':\n",
        "        return np.random.randint(30, 61)\n",
        "    elif text_value == '60-120 minutes a day':\n",
        "        return np.random.randint(60, 121)\n",
        "    elif text_value == 'Over 120 minutes a day':\n",
        "        return np.random.randint(120, 181)\n",
        "    else:\n",
        "        return 0\n",
        "\n",
        "use['TimeSearching'] = use['TimeSearching'].apply(random_time_picker)\n",
        "use['TimeSearching']"
